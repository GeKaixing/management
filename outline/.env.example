# Outline base
NODE_ENV=production
URL=http://127.0.0.1:13080
PORT=3000
SECRET_KEY=replace-with-secret-key
UTILS_SECRET=replace-with-utils-secret
FORCE_HTTPS=false
ENABLE_UPDATES=false

# PostgreSQL
POSTGRES_USER=outline
POSTGRES_PASSWORD=outlinepass
POSTGRES_DB=outline
DATABASE_URL=postgres://outline:outlinepass@postgres:5432/outline
PGSSLMODE=disable

# Redis
REDIS_URL=redis://redis:6379

# Local SMTP (for register/login email)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_DISABLE_STARTTLS=true
SMTP_FROM_EMAIL=Outline <noreply@outline.local>
SMTP_REPLY_EMAIL=support@outline.local

# Local file storage
FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
